[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/game_settings.gd" id="1_settings"]
[ext_resource type="Texture2D" uid="uid://rbp0s2hsuryd" path="res://assets/TileMap_SF/Grafika/bg.png" id="2_bg"]

[node name="GameSettings" type="Control"]
layout_mode = 3
